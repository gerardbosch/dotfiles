#!/usr/bin/env bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GREY='\033[0;90m'
NC='\033[0m'

echo -e "${YELLOW}=== Git Branch Cleanup (Gerrit) ===${NC}"
echo ""

remote_url=$(git remote get-url origin 2>/dev/null)
if [ -z "$remote_url" ]; then
  echo -e "${RED}Error: not inside a git repository with an 'origin' remote.${NC}"
  exit 1
fi

gerrit_host=$(echo "$remote_url" | sed -E 's|ssh://([^:/]+).*|\1|; s|([^:/]+):.*|\1|')
gerrit_port=$(echo "$remote_url" | grep -oE ':[0-9]+/' | tr -d ':/')
gerrit_port=${gerrit_port:-29418}

default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
default_branch=${default_branch:-master}

local_branches=$(git branch --format='%(refname:short)' | grep -v "^${default_branch}$")

if [ -z "$local_branches" ]; then
  echo "No local branches to check."
  exit 0
fi

echo -e "Querying Gerrit at ${CYAN}${gerrit_host}:${gerrit_port}${NC} for your changes..."
echo ""

# One call for all statuses; parse SHA→status pairs with python3
sha_status_map=$(ssh -p "$gerrit_port" "$gerrit_host" gerrit query \
  "owner:self" \
  --patch-sets --format=JSON 2>/dev/null \
  | python3 -c "
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
        if 'patchSets' in obj and 'status' in obj:
            for ps in obj['patchSets']:
                print(ps['revision'], obj['status'])
    except:
        pass
")

branches_to_delete=()
branch_details=()

while IFS= read -r branch; do
  tip_sha=$(git rev-parse "$branch" 2>/dev/null)
  gerrit_status=$(echo "$sha_status_map" | awk -v sha="$tip_sha" '$1 == sha {print $2}')

  case "$gerrit_status" in
    NEW)
      echo -e "  ${GREEN}open${NC}        $branch"
      ;;
    ABANDONED)
      echo -e "  ${GREY}abandoned${NC}   $branch"
      ;;
    MERGED)
      last_commit=$(git log -1 --format="%h - %s" "$branch" 2>/dev/null)
      branches_to_delete+=("$branch")
      branch_details+=("${CYAN}${branch}${NC}: ${last_commit}")
      ;;
    *)
      echo -e "  ${GREY}local-only${NC}  $branch"
      ;;
  esac
done <<< "$local_branches"

echo ""

if [ ${#branches_to_delete[@]} -eq 0 ]; then
  echo "No branches to delete (none are merged in Gerrit)."
  exit 0
fi

echo -e "${YELLOW}Merged branches to delete:${NC}"
for i in "${!branches_to_delete[@]}"; do
  echo -e "  $((i+1)). ${branch_details[$i]}"
done

echo ""
echo -e "${RED}WARNING: These branches will be permanently deleted${NC}"
read -p "Delete these branches? [y/N] " -r -n1
echo ""

if [[ $REPLY =~ ^[Yy]$ ]]; then
  for branch in "${branches_to_delete[@]}"; do
    git branch -D "$branch" \
      && echo -e "  ${GREEN}✓ deleted ${branch}${NC}" \
      || echo -e "  ${RED}✗ failed to delete ${branch}${NC}"
  done
  echo ""
  echo -e "${GREEN}✓ Cleanup complete${NC}"
else
  echo -e "${YELLOW}Cleanup cancelled${NC}"
fi